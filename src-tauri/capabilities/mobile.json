{
    "$schema": "https://schema.tauri.app/config/2",
    "identifier": "mobile",
    "local": true,
    "platforms": ["android", "iOS"],
    "windows": [
        "main"
    ],
    "permissions": [
        "core:default",
        "dialog:default",
        "fs:default",
        "fs:allow-write-text-file",
        "notification:default",
        "os:default",
        "biometric:allow-authenticate",
        "biometric:allow-status"
    ]
}
