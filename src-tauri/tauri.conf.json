{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "CryptoNote",
    "version": "0.1.0",
    "identifier": "com.cryptonote.desktop",
    "build": {
        "frontendDist": "../src-ui/dist",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "withGlobalTauri": false,
        "windows": [
            {
                "title": "CryptoNote",
                "width": 1100,
                "height": 720,
                "minWidth": 900,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false,
                "center": true,
                "decorations": true,
                "transparent": false,
                "devtools": false
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: asset: https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost https://api.pwnedpasswords.com"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/16x16.png",
            "icons/32x32.png",
            "icons/48x48.png",
            "icons/64x64.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/256x256.png",
            "icons/512x512.png",
            "icons/icon.png",
            "icons/icon.ico",
            "icons/icon.icns"
        ],
        "category": "Utility",
        "shortDescription": "Zero-knowledge offline-first password manager",
        "longDescription": "CryptoNote is a secure, offline-first password manager with zero-knowledge encrypted cloud sync.",
        "copyright": "© 2026 CryptoNote",
        "linux": {
            "deb": {
                "depends": [
                    "libssl-dev"
                ]
            },
            "rpm": {}
        },
        "windows": {
            "certificateThumbprint": null,
            "digestAlgorithm": "sha256",
            "timestampUrl": ""
        },
        "macOS": {
            "entitlements": null,
            "exceptionDomain": "",
            "signingIdentity": null
        },
        "android": {},
        "iOS": {}
    },
    "plugins": {
        "shell": {
            "open": false
        }
    }
}