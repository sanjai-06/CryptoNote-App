.env
.env.local
.env.*.local
server/.env

# ── Logs ─────────────────────────────────────────────────
logs/
*.log
server/logs/

# ── Database / vault files (user data — never commit) ────
*.db
*.db-shm
*.db-wal
*.sqlite
*.db-journal

# ── OS generated files ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

