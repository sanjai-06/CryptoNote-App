# CryptoNote Server – Environment Variables
# Copy this file to .env and set real values before running

# Server
PORT=3000

# MongoDB (local dev)
MONGO_URI=mongodb://localhost:27017/cryptonote

# MongoDB (Docker Compose — used by docker-compose.yml)
MONGODB_URI=mongodb://mongodb:27017/cryptonote

# JWT – MUST be changed to a secure 256-bit random key in production!
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-256-bit-random-key
JWT_EXPIRES=30d

# TLS (production only)
# TLS_KEY_PATH=/path/to/server.key
# TLS_CERT_PATH=/path/to/server.crt

# Optional: MongoDB auth
# MONGO_USER=cryptonote
# MONGO_PASS=changeme
